[60.462563, "o", "\u001b[1;83H\u001b[38;2;204;204;204;48;2;59;34;76mremove the whole `use` item\u001b[39m           \u001b[2;3H   \u001b[2;41H\u001b[38;2;255;205;28mtions::HashMap`\u001b[38;2;90;89;119m \u001b[3;1H\u001b[39m \u001b[3;3H   \u001b[3;7H \u001b[3;41H\u001b[38;2;255;205;28mn\u001b[38;2;90;89;119m \u001b[38;2;255;205;28mby\u001b[38;2;90;89;119m \u001b[38;2;255;205;28mdefault\u001b[38;2;90;89;119m \u001b[39m              \u001b[3;70H                                  \u001b[4;1H \u001b[4;5H\u001b[38;2;90;89;119m2\u001b[4;41H\u001b[39m                                      \u001b[4;80H                              \u001b[5;5H\u001b[38;2;90;89;119m3\u001b[5;14H\u001b[4m\u001b[38;2;255;255;255;2mRED\u001b[24m\u001b[38;2;164;160;232;22m:\u001b[38;2;90;89;119m \u001b[38;2;255;255;255mu32\u001b[38;2;90;89;119m \u001b[5;31H\u001b[38;2;232;220;160mff\u001b[5;35H00\u001b[5;50H\u001b[38;2;255;205;28mRED` is never used\u001b[39m \u001b[5;70H\u001b[38;2;255;205;28m`#[warn(dead_code)]` on by default\u001b[6;1H\u25cf\u001b[6;5H\u001b[38;2;90;89;119m4\u001b[6;8H\u001b[38;2;236;205;186mconst\u001b[38;2;90;89;119m \u001b[4m\u001b[38;2;255;255;255;2mGREEN\u001b[24m\u001b[38;2;164;160;232;22m:\u001b[38;2;90;89;119m \u001b[38;2;255;255;255mu32\u001b[38;2;90;89;119m   \u001b[38;2;219;191;239m=\u001b[38;2;90;89;119m \u001b[38;2;232;220;160m0x00ff00\u001b[38;2;164;160;232m;\u001b[38;2;90;89;119m \u001b[38;2;105;124;129m//\u001b[38;2;90;89;119m \u001b[38;2;105;124;129mdeliberately\u001b[38;2;90;89;119m \u001b[38;2;105;124;129mmisaligned\u001b[38;2;90;89;119m \u001b[38;2;105;124;129m(align\u001b[38;2;90;89;119m \u001b[38;2;105;124;129mprop)\u001b[38;2;90;89;119m \u001b[6;80H\u001b[38;2;255;205;28mconstant `GREEN` is never used\u001b[7;1H\u25cf\u001b[7;5H\u001b[38;2;90;89;119m5\u001b[7;7H\u001b[38;2;111;68;240m\u258d\u001b[38;2;236;205;186mconst\u001b[38;2;90;89;119m \u001b[4m\u001b[38;2;255;255;255;2mBLUE\u001b[24m\u001b[38;2;164;160;232;22m:\u001b[38;2;90;89;119m \u001b[7;21H\u001b[38;2;255;255;255m32\u001b[38;2;90;89;119m \u001b[7;25H  \u001b[38;2;219;191;239m=\u001b[38;2;90;89;119m \u001b[38;2;232;220;160m0x0000ff\u001b[38;2;164;160;232m;\u001b[38;2;90;89;119m \u001b[7;40H\u001b[38;2;255;205;28mconstant `BLUE` is never used\u001b[8;5H\u001b[38;2;90;89;119m6\u001b[8;8H \u001b[39m              \u001b[9;5H\u001b[38;2;90;89;119m7\u001b[9;8H\u001b[38;2;164;160;232m#[\u001b[38;2;239;186;93mderive\u001b[38;2;164;160;232m(\u001b[38;2;255;255;255mDebug\u001b[38;2;164;160;232m)]\u001b[38;2;90;89;119m \u001b[10;4H 8\u001b[10;8H\u001b[38;2;236;205;186mstruct\u001b[10;15H\u001b[38;2;255;255;255mPoint\u001b[38;2;90;89;119m \u001b[38;2;164;160;232m{\u001b[38;2;90;89;119m \u001b[11;4H 9\u001b[11;8H \u001b[11;10H  \u001b[38;2;255;255;255mx\u001b[38;2;164;160;232m:\u001b[38;2;90;89;119m \u001b[38;2;255;255;255mf64\u001b[38;2;164;160;232m,\u001b[38;2;90;89;119m \u001b[12;5H0\u001b[12;9H   \u001b[38;2;255;255;255my\u001b[38;2;164;160;232m:\u001b[38;2;90;89;119m \u001b[38;2;255;255;255mf64\u001b[38;2;164;160;232m,\u001b[38;2;90;89;119m \u001b[13;1H\u001b[39m \u001b[13;5H\u001b[38;2;90;89;119m1\u001b[13;8H\u001b[38;2;164;160;232m}\u001b[38;2;90;89;119m \u001b[39m           \u001b[13;22H                             \u001b[14;5H\u001b[38;2;90;89;119m2\u001b[14;9H\u001b[39m                                    \u001b[15;1H\u001b[38;2;204;204;204m\u25cf\u001b[15;5H\u001b[38;2;90;89;119m3\u001b[15;8H\u001b[4m\u001b[38;2;236;205;186mimpl\u001b[38;2;90;89;119m \u001b[38;2;255;255;255mPoint\u001b[24m\u001b[38;2;90;89;119m \u001b[38;2;164;160;232m{\u001b[15;21H\u001b[39m \u001b[38;2;204;204;204mmethod in this implementation\u001b[16;5H\u001b[38;2;90;89;119m4\u001b[16;12H\u001b[38;2;236;205;186mfn\u001b[38;2;90;89;119m \u001b[38;2;255;255;255mnew\u001b[38;2;164;160;232m(x:\u001b[38;2;90;89;119m \u001b[38;2;255;255;255mf64\u001b[38;2;164;160;232m,\u001b[38;2;90;89;119m \u001b[38;2;164;160;232my:\u001b[38;2;90;89;119m \u001b[38;2;255;255;255mf64\u001b[38;2;164;160;232m)\u001b