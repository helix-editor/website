[69.695334, "o", "\u001b[4;9H\u001b[38;2;164;160;232;48;2;59;34;76mm\u001b[4;56H3\u001b[4;63H\u001b[38;2;90;89;119m \u001b[38;2;105;124;129m//\u001b[38;2;90;89;119m \u001b[38;2;105;124;129mintentionally\u001b[38;2;90;89;119m \u001b[38;2;105;124;129munused\u001b[38;2;90;89;119m \u001b[38;2;105;124;129m\u2192\u001b[38;2;90;89;119m \u001b[38;2;105;124;129mcode-action\u001b[38;2;90;89;119m \u001b[38;2;105;124;129mprop\u001b[38;2;90;89;119m \u001b[39m      \u001b[5;63H\u001b[38;2;90;89;119m \u001b[39m                                        \u001b[6;11H\u001b[38;2;255;255;255msrc/\u001b[1mm\u001b[22main.rs\u001b[6;63H\u001b[38;2;236;205;186mconst\u001b[38;2;90;89;119m \u001b[4m\u001b[38;2;255;255;255;2mRED\u001b[24m\u001b[38;2;164;160;232;22m:\u001b[38;2;90;89;119m \u001b[38;2;255;255;255mu32\u001b[38;2;90;89;119m     \u001b[38;2;219;191;239m=\u001b[38;2;90;89;119m \u001b[38;2;232;220;160m0xff0000\u001b[38;2;164;160;232m;\u001b[38;2;90;89;119m \u001b[7;19H\u001b[38;2;239;186;93;1mm\u001b[7;63H\u001b[38;2;236;205;186;22mconst\u001b[38;2;90;89;119m \u001b[4m\u001b[38;2;255;255;255;2mGREEN\u001b[24m\u001b[38;2;164;160;232;22m:\u001b[38;2;90;89;119m \u001b[38;2;255;255;255mu32\u001b[38;2;90;89;119m   \u001b[38;2;219;191;239m=\u001b[38;2;90;89;119m \u001b[38;2;232;220;160m0x00ff00\u001b[38;2;164;160;232m;\u001b[38;2;90;89;119m \u001b[38;2;105;124;129m//\u001b[38;2;90;89;119m \u001b[38;2;105;124;129mdeliberately\u001b[38;2;90;89;119m \u001b[38;2;105;124;129mmis\u001b[8;28H\u001b[38;2;239;186;93;1mm\u001b[8;63H\u001b[38;2;236;205;186;22mconst\u001b[38;2;90;89;119m \u001b[4m\u001b[38;2;255;255;255;2mBLUE\u001b[24m\u001b[38;2;164;160;232;22m:\u001b[8;75H\u001b[38;2;255;255;255mu32\u001b[38;2;90;89;119m    \u001b[38;2;219;191;239m=\u001b[38;2;90;89;119m \u001b[38;2;232;220;160m0x0000ff\u001b[38;2;164;160;232m;\u001b[38;2;90;89;119m \u001b[9;11H\u001b[38;2;164;160;232m           \u001b[9;63H\u001b[38;2;90;89;119m \u001b[39m                   \u001b[10;63H\u001b[38;2;164;160;232m#[\u